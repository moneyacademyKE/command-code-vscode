{
  "packageManager": "pnpm@11.7.0",
  "name": "cmd-lite",
  "displayName": "CMD Lite",
  "description": "A coding agent with taste. Wrap the Command Code (`cmd`) CLI as a native VS Code experience.",
  "version": "0.5.3",
  "publisher": "moneyacademyke",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moneyacademyKE/cmd-lite"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Education",
    "Other"
  ],
  "keywords": [
    "command-code",
    "cmd",
    "taste",
    "ai",
    "coding-agent",
    "anthropic",
    "claude",
    "deepseek"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/icon.png",
  "contributes": {
    "chatParticipants": [
      {
        "id": "cmd-lite.chat",
        "name": "cmd",
        "fullName": "Command Code",
        "description": "Your coding agent with taste. Multi-model, plan mode, and continuous learning.",
        "commands": [
          {
            "name": "plan",
            "description": "Plan before building"
          },
          {
            "name": "review",
            "description": "Review code or a PR"
          },
          {
            "name": "taste",
            "description": "Inspect or apply taste"
          },
          {
            "name": "learn",
            "description": "Learn taste from a repository"
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cmd-lite-viewContainer",
          "title": "Command Code",
          "icon": "assets/circuit-board.svg"
        }
      ]
    },
    "views": {
      "cmd-lite-viewContainer": [
        {
          "id": "cmd-lite.chatView",
          "name": "Chat",
          "type": "webview",
          "icon": "$(comment-discussion)"
        },
        {
          "id": "cmd-lite.tasteView",
          "name": "Taste",
          "icon": "$(book)"
        },
        {
          "id": "cmd-lite.sessionView",
          "name": "Sessions",
          "icon": "$(history)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cmd-lite.tasteView",
        "contents": "No taste learned yet.\n[Learn from current repo](command:commandcode.taste.learnHere)\n[Pull taste package](command:commandcode.taste.pull)\n[Open taste docs](https://commandcode.ai/docs/taste)"
      }
    ],
    "commands": [
      {
        "command": "cmd-lite.start",
        "title": "Start Command Code Session",
        "shortTitle": "Start Session",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.continue",
        "title": "Continue Last Session",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.resume",
        "title": "Resume Past Session",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.print",
        "title": "Run Query (Headless)",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.plan",
        "title": "Plan Mode",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.review",
        "title": "Review Pull Request",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.model.pick",
        "title": "Pick Model",
        "category": "Command Code",
        "shortTitle": "Switch Model"
      },
      {
        "command": "cmd-lite.permission.pick",
        "title": "Pick Permission Mode",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.taste.openFile",
        "title": "Open Taste File",
        "category": "Command Code",
        "icon": "$(go-to-file)"
      },
      {
        "command": "cmd-lite.taste.push",
        "title": "Push Taste Package",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.taste.pull",
        "title": "Pull Taste Package",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.taste.list",
        "title": "List Taste Packages",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.taste.lint",
        "title": "Lint Taste Package",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.taste.learnHere",
        "title": "Learn Taste From Current Folder",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.taste.openWeb",
        "title": "Open Taste Profile on commandcode.ai",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.status",
        "title": "Show Command Code Status",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.info",
        "title": "Show System Info",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.login",
        "title": "Login to Command Code",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.logout",
        "title": "Logout of Command Code",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.update",
        "title": "Update Command Code CLI",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.whoami",
        "title": "Show Current User",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.diff.show",
        "title": "Show Diff",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.agents.parallel",
        "title": "Run Parallel Agents",
        "category": "Command Code"
      },
      {
        "command": "cmd-lite.session.exportMarkdown",
        "title": "Export Session as Markdown",
        "category": "Command Code",
        "icon": "$(export)"
      },
      {
        "command": "cmd-lite.diff.acceptAll",
        "title": "Accept All Changes",
        "category": "Command Code",
        "icon": "$(check-all)"
      },
      {
        "command": "cmd-lite.diff.rejectAll",
        "title": "Reject All Changes",
        "category": "Command Code",
        "icon": "$(close-all)"
      },
      {
        "command": "cmd-lite.checkpoint.restore",
        "title": "Restore Last Checkpoint",
        "category": "Command Code",
        "icon": "$(discard)"
      }
    ],
    "configuration": {
      "title": "Command Code",
      "properties": {
        "cmd-lite.cliPath": {
          "type": "string",
          "default": "cmd",
          "description": "Path to the `cmd` CLI binary. Override if you installed Command Code to a non-standard location."
        },
        "cmd-lite.localRegistryPath": {
          "type": "string",
          "default": "",
          "description": "Local repository directory path override for `cmd` CLI auto-updates. If set, tarballs are read from this directory instead of npm."
        },
        "cmd-lite.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Model to use by default (e.g. claude-opus-4.8, deepseek-v4-pro). Leave empty to use CLI default."
        },
        "cmd-lite.defaultPermissionMode": {
          "type": "string",
          "enum": [
            "standard",
            "plan",
            "auto-accept"
          ],
          "default": "standard",
          "description": "Permission mode for new sessions."
        },
        "cmd-lite.maxTurns": {
          "type": "number",
          "default": 10,
          "description": "Cap on conversation turns in headless / print mode."
        },
        "cmd-lite.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the session indicator in the status bar."
        },
        "cmd-lite.context.maxSelectionLength": {
          "type": "number",
          "default": 10000,
          "description": "Maximum characters of selected text to share with the CLI via the context server. Larger values mean more context for the AI but may slow down IPC."
        }
      }
    },
    "languageModelTools": [
      {
        "name": "cmd-lite_runPrint",
        "tags": [
          "cmd-lite",
          "ai",
          "coding"
        ],
        "toolReferenceName": "runPrint",
        "displayName": "Run Command Code",
        "modelDescription": "Run Command Code (cmd) with a given prompt. Command Code is an AI coding agent with taste. It can write code, fix bugs, refactor, run tests, and more. Use this tool when the user asks to make code changes, fix issues, or implement features. Returns the output from the coding agent.",
        "userDescription": "Run Command Code coding agent with a prompt",
        "canBeReferencedInPrompt": true,
        "icon": "$(circuit-board)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "prompt": {
              "type": "string",
              "description": "The prompt to send to Command Code. Be specific about what code changes are needed, which files to modify, and the expected outcome."
            },
            "model": {
              "type": "string",
              "description": "Optional model to use (e.g. claude-opus-4.8, deepseek-v4-pro). Leave empty to use the default."
            },
            "maxTurns": {
              "type": "number",
              "description": "Maximum conversation turns (default: 10)."
            },
            "plan": {
              "type": "boolean",
              "description": "If true, Command Code operates in plan mode and does NOT modify files, only proposes a plan."
            }
          },
          "required": [
            "prompt"
          ]
        }
      },
      {
        "name": "cmd-lite_getTaste",
        "tags": [
          "cmd-lite",
          "taste"
        ],
        "toolReferenceName": "getTaste",
        "displayName": "Get Taste",
        "modelDescription": "Retrieve the learned coding taste/preferences for the current project from .commandcode/taste/taste.md. Taste includes coding conventions, style preferences, technology choices, and patterns specific to this project. Use this before making code changes to ensure the output matches the project's conventions.",
        "userDescription": "Get learned project coding taste",
        "canBeReferencedInPrompt": true,
        "icon": "$(book)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cwd": {
              "type": "string",
              "description": "Optional working directory. Defaults to the active workspace folder."
            }
          }
        }
      },
      {
        "name": "cmd-lite_getDiagnostics",
        "tags": [
          "cmd-lite",
          "diagnostics"
        ],
        "toolReferenceName": "getDiagnostics",
        "displayName": "Get Diagnostics",
        "modelDescription": "Retrieve VS Code diagnostics (errors, warnings, hints) for open files. Useful for understanding current problems in the codebase before making changes. Returns diagnostics grouped by file with severity, line number, and message.",
        "userDescription": "Get VS Code diagnostics for current files",
        "canBeReferencedInPrompt": true,
        "icon": "$(warning)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filePath": {
              "type": "string",
              "description": "Optional specific file path to get diagnostics for. If omitted, returns diagnostics for all open files."
            }
          }
        }
      },
      {
        "name": "cmd-lite_getGitContext",
        "tags": [
          "cmd-lite",
          "git"
        ],
        "toolReferenceName": "getGitContext",
        "displayName": "Get Git Context",
        "modelDescription": "Retrieve the current git context for the workspace: current branch, HEAD commit hash, commit message, and list of dirty (modified/uncommitted) files. Use this to understand what the user is working on before making code changes.",
        "userDescription": "Get current git status and branch info",
        "canBeReferencedInPrompt": true,
        "icon": "$(git-branch)"
      },
      {
        "name": "cmd-lite_getOpenFiles",
        "tags": [
          "cmd-lite",
          "editor"
        ],
        "toolReferenceName": "getOpenFiles",
        "displayName": "Get Open Files",
        "modelDescription": "Retrieve the list of currently open files in the editor, including file paths, languages, and which file is active. Use this to understand what the user has open before suggesting changes.",
        "userDescription": "Get list of open editor files",
        "canBeReferencedInPrompt": true,
        "icon": "$(files)"
      },
      {
        "name": "cmd-lite_listModels",
        "tags": [
          "cmd-lite",
          "models"
        ],
        "toolReferenceName": "listModels",
        "displayName": "List Available Models",
        "modelDescription": "List all available AI models that Command Code can use, including model IDs and provider names. Use this when the user asks about model options or wants to switch models.",
        "userDescription": "List available AI models for Command Code",
        "canBeReferencedInPrompt": true,
        "icon": "$(symbol-misc)"
      },
      {
        "name": "cmd-lite_runParallel",
        "tags": [
          "cmd-lite",
          "agents"
        ],
        "toolReferenceName": "runParallel",
        "displayName": "Run Parallel Agents",
        "modelDescription": "Run multiple Command Code agents in parallel, each with a different task. Useful for doing multiple things at once like implementing a feature while writing tests and docs. Each agent runs independently and results are merged.",
        "userDescription": "Run multiple Command Code agents in parallel",
        "canBeReferencedInPrompt": true,
        "icon": "$(multiple-windows)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "tasks": {
              "type": "array",
              "description": "Array of tasks. Each task has a label and prompt.",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Short label for this agent (e.g. 'impl', 'tests', 'docs')"
                  },
                  "prompt": {
                    "type": "string",
                    "description": "The prompt for this specific agent"
                  },
                  "model": {
                    "type": "string",
                    "description": "Optional model override for this agent"
                  },
                  "planMode": {
                    "type": "boolean",
                    "description": "If true, this agent operates in plan mode"
                  }
                },
                "required": [
                  "label",
                  "prompt"
                ]
              }
            },
            "model": {
              "type": "string",
              "description": "Default model for all agents"
            },
            "maxTurns": {
              "type": "number",
              "description": "Max turns per agent"
            },
            "planMode": {
              "type": "boolean",
              "description": "Default plan mode for all agents"
            }
          },
          "required": [
            "tasks"
          ]
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cmd-lite.print",
          "when": "editorTextFocus",
          "group": "cmd-lite"
        }
      ],
      "explorer/context": [
        {
          "command": "cmd-lite.print",
          "group": "cmd-lite"
        }
      ],
      "view/item/context": [
        {
          "command": "cmd-lite.session.exportMarkdown",
          "when": "view == cmd-lite.sessionView && viewItem == session",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cmd-lite.start",
        "key": "ctrl+shift+`",
        "mac": "cmd+shift+`"
      }
    ],
    "taskDefinitions": [
      {
        "type": "cmd-lite",
        "properties": {
          "task": {
            "type": "string",
            "description": "The task to run (headless)"
          }
        }
      }
    ]
  },
  "scripts": {
    "preinstall": "bb scripts/enforce-package-manager.clj",
    "prepare": "bb scripts/install-hooks.clj",
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "playwright": "^1.61.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "marked": "^18.0.5"
  }
}
